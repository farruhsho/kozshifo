# ── KO'Z SHIFO backend configuration ──────────────────────────────────────────
# Copy to `.env` and adjust. All values have safe local-dev defaults in config.py.

# App
APP_NAME="KO'Z SHIFO API"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# Security — CHANGE THIS IN PRODUCTION (use: python -c "import secrets;print(secrets.token_urlsafe(48))")
SECRET_KEY=dev-insecure-change-me-please-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Database
# Local dev defaults to SQLite (zero setup). For production set a Postgres DSN, e.g.:
# DATABASE_URL=postgresql+psycopg://kozshifo:secret@localhost:5432/kozshifo
DATABASE_URL=sqlite:///./kozshifo.db

# CORS — comma-separated origins for the Flutter web client / admin
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Seed — director (system owner) bootstrap account created on first run
SEED_DIRECTOR_EMAIL=director@kozshifo.uz
SEED_DIRECTOR_PASSWORD=Director!2026
SEED_ON_STARTUP=true
