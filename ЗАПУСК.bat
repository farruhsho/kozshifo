@echo off
chcp 65001 >nul
rem ============================================================
rem  KO'Z SHIFO — запуск в один клик.
rem  Поднимает сервер (он же отдаёт веб-приложение и API на одном
rem  адресе) и сам открывает рабочее приложение в браузере.
rem
rem  ВАЖНО: вход работает на http://127.0.0.1:8000 (этот файл).
rem  НЕ заходи на kozshifo-32e6f.web.app — там сервер ещё не
rem  развёрнут (нужен план Blaze), оттуда будет «Ошибка 404».
rem ============================================================
cd /d "%~dp0backend"
echo.
echo   KO'Z SHIFO запускается...
echo   Приложение откроется в браузере: http://127.0.0.1:8000
echo   Логин: director@kozshifo.uz  /  Director!2026
echo.
echo   Это окно держи открытым. Закрыть сервер — Ctrl+C.
echo.
rem Открыть браузер с задержкой 4с (к этому моменту сервер уже поднят).
rem explorer <url> открывает браузер по умолчанию без возни с кавычками:
start "" cmd /c "timeout /t 4 >nul & explorer http://127.0.0.1:8000"
".venv\Scripts\python.exe" -m uvicorn app.main:app --host 127.0.0.1 --port 8000
pause
